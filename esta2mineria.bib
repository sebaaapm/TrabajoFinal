@article{hilbe_statistical_2017,
	title = {The statistical analysis of count data / {El} análisis estadístico de los datos de recuento},
	volume = {29},
	issn = {1135-6405},
	url = {https://journals.sagepub.com/action/showAbstract},
	doi = {10.1080/11356405.2017.1368162},
	abstract = {This monograph provides an overview of the various regression models used to analyse count response models. We begin by defining counts and the methods used to model count data. We then discuss the basic count model — Poisson regression — focusing on the nature of equi-dispersion, which occurs when the mean and variance are identical in value. Equi-dispersion is a distributional assumption of the Poisson model. We examine how to determine when this assumption is violated, which results in extra-dispersion; i.e., either under- or overdispersion. Extra-dispersion biases the Poisson model standard errors, leading us to accept or reject a model when we should not. The negative binomial model is generally used to model generic overdispersion, but if we know the cause of the overdispersion we can select an alternative count model that appropriately adjusts for it. The same is the case with under-dispersion. Aside from looking at the Poisson and negative binomial models, we also evaluate models such as generalized Poisson, Poisson inverse Gaussian, two-part hurdle models, zero-inflated mixture models and other varieties of count model. Finally, we provide a brief look at Bayesian count models, showing how to estimate a Bayesian negative binomial model.},
	language = {EN},
	number = {3},
	urldate = {2026-06-16},
	journal = {Culture and Education},
	publisher = {SAGE Publications},
	author = {Hilbe, Joseph M.},
	month = oct,
	year = {2017},
	pages = {409--460},
	file = {PDF:C\:\\Users\\Sebastian\\Zotero\\storage\\9ECBRR34\\Hilbe - 2017 - The statistical analysis of count data  El análisis estadístico de los datos de recuento.pdf:application/pdf},
}

@article{saavedra_local_2021,
	title = {Local incentives and national tax evasion: {The} response of illegal mining to a tax reform in {Colombia}},
	volume = {138},
	issn = {0014-2921},
	shorttitle = {Local incentives and national tax evasion},
	url = {https://www.sciencedirect.com/science/article/pii/S0014292121001768},
	doi = {10.1016/j.euroecorev.2021.103843},
	abstract = {Achieving a fair distribution of resources is one of the goals of fiscal policy. To this end, governments often transfer tax resources from richer to more marginalized areas. In the context of mining in Colombia, we study whether lower transfers to the locality where the taxed economic activity takes place dampen local authorities’ incentives to curb tax evasion. Using machine learning predictions on satellite imagery to identify mines allows us to overcome the challenge of measuring evasion. Employing difference-in-differences strategies, we find that reducing the share of revenue transferred back to mining municipalities leads to an increase in illegal mining. This result highlights the difficulties inherent in adequately redistributing tax revenues.},
	urldate = {2026-06-16},
	journal = {European Economic Review},
	author = {Saavedra, Santiago and Romero, Mauricio},
	month = sep,
	year = {2021},
	keywords = {Colombia, Illegal mining, Satellite images, Tax evasion},
	pages = {103843},
	file = {PDF:C\:\\Users\\Sebastian\\Zotero\\storage\\6GVLNT52\\Saavedra y Romero - 2021 - Local incentives and national tax evasion The response of illegal mining to a tax reform in Colombi.pdf:application/pdf},
}
